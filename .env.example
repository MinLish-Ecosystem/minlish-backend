# ===== SERVER =====
PORT=3000
NODE_ENV=development

# ===== MONGODB =====
# Local (dùng khi dev offline)
MONGO_URI_LOCAL=mongodb://localhost:27017/minlish
# Atlas (dùng khi deploy / khi muốn kết nối cloud)
MONGO_URI_ATLAS=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/minlish

# ===== JWT =====
# Secret key cho Access Token (nên dùng chuỗi dài, random)
JWT_ACCESS_SECRET=your_super_secret_access_key_here
# Secret key cho Refresh Token (dùng chuỗi KHÁC với access)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
# Thời gian sống của Access Token (15m, 30m, 1h...)
JWT_ACCESS_EXPIRES_IN=15m
# Thời gian sống của Refresh Token (7d, 30d...)
JWT_REFRESH_EXPIRES_IN=7d

# ===== GMAIL SMTP =====
# Email của bạn (địa chỉ gmail)
MAIL_USER=your_email@gmail.com
# App Password - KHÔNG phải mật khẩu gmail thật!
# Hướng dẫn tạo: Google Account > Security > 2-Step Verification > App Passwords
MAIL_PASS=your_gmail_app_password_here

# ===== CLOUDINARY (để sau) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
